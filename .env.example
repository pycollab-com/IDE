# Optional local overrides for the offline IDE branch

# Override the local app data directory.
PYCOLLAB_IDE_HOME=

# Override the Python executable used by the Electron shell.
PYCOLLAB_IDE_PYTHON=

# Browser runtime (Pyodide)
PYCOLLAB_PYODIDE_VERSION=0.29.3
PYCOLLAB_PYODIDE_BASE_URL=/vendor/pyodide/v0.29.3/full/
