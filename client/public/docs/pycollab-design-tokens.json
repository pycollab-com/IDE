{
  "meta": {
    "name": "PyCollab Design Tokens",
    "version": "1.0.0",
    "updated": "2026-02-22",
    "baseUnit": 8
  },
  "primitives": {
    "color": {
      "primary": {
        "trustBlue": {
          "hex": "#2D6CDF",
          "rgb": "45 108 223",
          "hsl": "219 74% 53%"
        },
        "collabTeal": {
          "hex": "#00A8B5",
          "rgb": "0 168 181",
          "hsl": "184 100% 35%"
        },
        "pyOlive": {
          "hex": "#899878",
          "rgb": "137 152 120",
          "hsl": "88 13% 53%"
        },
        "signalLime": {
          "hex": "#B8D66A",
          "rgb": "184 214 106",
          "hsl": "77 57% 63%"
        },
        "sparkOrange": {
          "hex": "#FF8B3D",
          "rgb": "255 139 61",
          "hsl": "24 100% 62%"
        },
        "graphite": {
          "hex": "#121113",
          "rgb": "18 17 19",
          "hsl": "270 6% 7%"
        },
        "ivory": {
          "hex": "#F7F7F2",
          "rgb": "247 247 242",
          "hsl": "60 24% 96%"
        }
      },
      "semantic": {
        "success": {
          "light": "#1F9D61",
          "dark": "#39C980"
        },
        "warning": {
          "light": "#B26A00",
          "dark": "#FFB449"
        },
        "error": {
          "light": "#C7362D",
          "dark": "#FF6E64"
        },
        "info": {
          "light": "#2D6CDF",
          "dark": "#6F97FF"
        }
      }
    },
    "spacing": {
      "0_5": 4,
      "1": 8,
      "1_5": 12,
      "2": 16,
      "3": 24,
      "4": 32,
      "6": 48,
      "8": 64,
      "12": 96,
      "16": 128
    },
    "radius": {
      "xs": 8,
      "sm": 10,
      "md": 12,
      "lg": 16,
      "xl": 20,
      "pill": 999
    },
    "shadow": {
      "sm": "0 1px 2px rgba(18, 17, 19, 0.12)",
      "md": "0 8px 24px rgba(18, 17, 19, 0.16)",
      "lg": "0 16px 40px rgba(18, 17, 19, 0.22)",
      "focus": "0 0 0 3px rgba(45, 108, 223, 0.35)"
    },
    "motion": {
      "duration": {
        "fast": "120ms",
        "base": "180ms",
        "slow": "280ms"
      },
      "easing": {
        "standard": "cubic-bezier(0.2, 0, 0, 1)",
        "emphasized": "cubic-bezier(0.2, 0, 0, 1.2)",
        "exit": "cubic-bezier(0.4, 0, 1, 1)"
      }
    },
    "typography": {
      "family": {
        "sans": "SF Pro Display, SF Pro Text, -apple-system, BlinkMacSystemFont, Segoe UI, sans-serif",
        "mono": "SF Mono, JetBrains Mono, ui-monospace, monospace"
      },
      "weight": {
        "ultraLight": 100,
        "thin": 200,
        "light": 300,
        "regular": 400,
        "medium": 500,
        "semibold": 600,
        "bold": 700,
        "heavy": 800,
        "black": 900
      },
      "roles": {
        "display": {
          "desktop": { "fontSize": 56, "lineHeight": 64, "letterSpacing": -0.02, "weight": 700 },
          "tablet": { "fontSize": 48, "lineHeight": 56, "letterSpacing": -0.02, "weight": 700 },
          "mobile": { "fontSize": 40, "lineHeight": 46, "letterSpacing": -0.015, "weight": 700 }
        },
        "headline": {
          "desktop": { "fontSize": 40, "lineHeight": 48, "letterSpacing": -0.015, "weight": 700 },
          "tablet": { "fontSize": 34, "lineHeight": 42, "letterSpacing": -0.01, "weight": 700 },
          "mobile": { "fontSize": 30, "lineHeight": 38, "letterSpacing": -0.01, "weight": 700 }
        },
        "title": {
          "desktop": { "fontSize": 30, "lineHeight": 38, "letterSpacing": -0.01, "weight": 600 },
          "tablet": { "fontSize": 28, "lineHeight": 34, "letterSpacing": -0.008, "weight": 600 },
          "mobile": { "fontSize": 24, "lineHeight": 30, "letterSpacing": -0.006, "weight": 600 }
        },
        "body": {
          "desktop": { "fontSize": 18, "lineHeight": 30, "letterSpacing": 0, "weight": 400 },
          "tablet": { "fontSize": 17, "lineHeight": 28, "letterSpacing": 0, "weight": 400 },
          "mobile": { "fontSize": 16, "lineHeight": 26, "letterSpacing": 0, "weight": 400 }
        },
        "callout": {
          "desktop": { "fontSize": 17, "lineHeight": 26, "letterSpacing": 0, "weight": 500 },
          "tablet": { "fontSize": 16, "lineHeight": 24, "letterSpacing": 0, "weight": 500 },
          "mobile": { "fontSize": 15, "lineHeight": 22, "letterSpacing": 0, "weight": 500 }
        },
        "subheadline": {
          "desktop": { "fontSize": 16, "lineHeight": 24, "letterSpacing": 0.002, "weight": 500 },
          "tablet": { "fontSize": 15, "lineHeight": 22, "letterSpacing": 0.002, "weight": 500 },
          "mobile": { "fontSize": 14, "lineHeight": 20, "letterSpacing": 0.002, "weight": 500 }
        },
        "footnote": {
          "desktop": { "fontSize": 14, "lineHeight": 20, "letterSpacing": 0.004, "weight": 500 },
          "tablet": { "fontSize": 13, "lineHeight": 18, "letterSpacing": 0.004, "weight": 500 },
          "mobile": { "fontSize": 12, "lineHeight": 17, "letterSpacing": 0.004, "weight": 500 }
        },
        "caption": {
          "desktop": { "fontSize": 12, "lineHeight": 16, "letterSpacing": 0.006, "weight": 500 },
          "tablet": { "fontSize": 12, "lineHeight": 16, "letterSpacing": 0.006, "weight": 500 },
          "mobile": { "fontSize": 11, "lineHeight": 14, "letterSpacing": 0.006, "weight": 500 }
        }
      }
    },
    "grid": {
      "columns": 12,
      "breakpoints": {
        "xs": 0,
        "sm": 480,
        "md": 768,
        "lg": 1024,
        "xl": 1440
      },
      "layout": {
        "desktop": {
          "width": 1440,
          "gutter": 24,
          "margin": 60,
          "column": 88
        },
        "tablet": {
          "width": 768,
          "gutter": 16,
          "margin": 32,
          "column": 44
        },
        "mobile": {
          "width": 375,
          "gutter": 12,
          "margin": 16,
          "column": 17.58
        }
      },
      "safeArea": {
        "top": "env(safe-area-inset-top)",
        "right": "env(safe-area-inset-right)",
        "bottom": "env(safe-area-inset-bottom)",
        "left": "env(safe-area-inset-left)"
      }
    }
  },
  "themes": {
