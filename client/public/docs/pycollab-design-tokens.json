      "maxVisible": 5,
      "overlap": 8,
      "counterSize": 32
    },
    "imageContainer": {
      "radius": "{primitives.radius.lg}",
      "ratios": ["1:1", "4:3", "16:9"],
      "captionGap": 8
    },
    "videoPlayer": {
