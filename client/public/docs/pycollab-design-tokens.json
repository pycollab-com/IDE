  "aliases": {
    "color": {
      "brandPrimary": "{primitives.color.primary.trustBlue.hex}",
      "brandSecondary": "{primitives.color.primary.pyOlive.hex}",
      "collaboration": "{primitives.color.primary.collabTeal.hex}",
      "attention": "{primitives.color.primary.sparkOrange.hex}",
      "success": "{themes.light.semantic.success}",
      "warning": "{themes.light.semantic.warning}",
      "error": "{themes.light.semantic.error}",
      "info": "{themes.light.semantic.info}"
    }
  },
  "components": {
    "header": {
      "height": {
        "desktop": 72,
        "mobile": 64
      },
      "paddingX": 24,
