    "progressCircle": {
      "sizes": {
        "sm": 20,
        "md": 32,
        "lg": 48
      },
      "strokeWidth": 3
    },
    "skeleton": {
      "animationDuration": "1.2s",
      "radius": "{primitives.radius.sm}",
      "baseAlpha": 0.12,
      "highlightAlpha": 0.2
    },
    "emptyState": {
      "minHeight": 280,
      "contentMaxWidth": 480,
      "gap": 12
    },
    "card": {
      "padding": {
        "compact": 16,
        "default": 24
      },
      "radius": "{primitives.radius.lg}",
      "borderWidth": 1,
      "shadow": "{primitives.shadow.sm}"
    },
    "table": {
      "rowHeight": {
        "dense": 44,
        "standard": 52
      },
      "cellPadding": "12px 16px",
      "headerWeight": 600
    },
    "list": {
      "itemMinHeight": 48,
      "dividerInset": 16,
      "paddingX": 16
    },
    "statTile": {
      "minHeight": 120,
      "padding": 16,
      "radius": "{primitives.radius.md}"
    },
    "lineChart": {
      "minHeight": 240,
      "strokeWidth": 2,
      "pointSize": 6
    },
    "barChart": {
      "minHeight": 240,
      "barRadius": 6,
      "groupGap": 10
    },
    "heatmap": {
      "cellSize": 16,
      "cellGap": 3,
      "legendSteps": 5
    },
