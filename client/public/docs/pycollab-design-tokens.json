      },
      "state": {
        "focus": "rgba(45,108,223,0.35)",
        "hoverOverlay": "rgba(18,17,19,0.04)",
        "pressedOverlay": "rgba(18,17,19,0.08)",
        "disabled": "rgba(18,17,19,0.3)",
        "disabledSurface": "rgba(18,17,19,0.08)"
      },
      "semantic": {
        "success": "#1F9D61",
        "warning": "#B26A00",
        "error": "#C7362D",
        "info": "#2D6CDF"
      }
    },
    "dark": {
      "surface": {
        "base": "#121113",
        "elevated": "#1A1920",
        "subtle": "#252430",
        "inverse": "#F7F7F2"
      },
      "text": {
        "primary": "#F7F7F2",
        "secondary": "rgba(247,247,242,0.72)",
        "tertiary": "rgba(247,247,242,0.54)",
        "inverse": "#121113",
        "link": "#6F97FF"
      },
      "border": {
        "default": "rgba(247,247,242,0.18)",
        "strong": "rgba(247,247,242,0.32)",
        "inverse": "rgba(18,17,19,0.24)"
      },
      "state": {
        "focus": "rgba(111,151,255,0.5)",
        "hoverOverlay": "rgba(247,247,242,0.08)",
        "pressedOverlay": "rgba(247,247,242,0.14)",
        "disabled": "rgba(247,247,242,0.42)",
        "disabledSurface": "rgba(247,247,242,0.12)"
      },
      "semantic": {
        "success": "#39C980",
        "warning": "#FFB449",
        "error": "#FF6E64",
        "info": "#6F97FF"
      }
    }
