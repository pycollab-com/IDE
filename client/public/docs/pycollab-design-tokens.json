        "tertiary": "rgba(18,17,19,0.5)",
        "inverse": "#F7F7F2",
        "link": "#2D6CDF"
      },
      "border": {
        "default": "rgba(18,17,19,0.14)",
        "strong": "rgba(18,17,19,0.24)",
